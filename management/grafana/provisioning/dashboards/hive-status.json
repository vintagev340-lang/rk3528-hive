    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "options": {
                "0": { "color": "green", "index": 0, "text": "All Systems Operational" }
              },
              "type": "value"
            },
            {
              "options": {
                "from": 1,
                "result": { "color": "red", "index": 1, "text": "Degraded" },
                "to": 10000
              },
              "type": "range"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 10, "x": 14, "y": 0 },
      "id": 4,
      "options": {
        "colorMode": "background",
