#!/bin/bash
#
# Hive Network Services Status Display
# Custom MOTD script for Hive Network Node

THIS_SCRIPT="hive-services"
MOTD_DISABLE=""

safe_source() { [[ -f "$1" ]] && . "$1"; }

# Load MOTD config
safe_source /etc/default/armbian-motd
for f in ${MOTD_DISABLE}; do
    [[ "${f}" == "${THIS_SCRIPT}" ]] && exit 0
done

# Load hive node configuration
safe_source /etc/hive/config.env

# ── 并行：后台网络检测 + 一次性批量读取所有服务状态 ─────────
_TMP=$(mktemp -d)

ping -c1 -W2 8.8.8.8 >/dev/null 2>&1 \
    && echo "connected" > "${_TMP}/inet" \
    || echo "disconnected" > "${_TMP}/inet" &
_INET_PID=$!

if command -v tailscale &>/dev/null; then
    tailscale status --peers=false >/dev/null 2>&1 \
        && echo "connected" > "${_TMP}/ts" \
        || echo "disconnected" > "${_TMP}/ts" &
    _TS_PID=$!
fi

# 一次 systemctl 拿到所有单元状态（替代 N×2 次 fork）
declare -A _SVC_ACTIVE _SVC_ENABLED
while IFS=$'\t' read -r unit active; do
    _SVC_ACTIVE["$unit"]="$active"
done < <(systemctl list-units --type=service --all --no-legend --no-pager \
    --plain -o cat 2>/dev/null | awk '{printf "%s\t%s\n", $1, $3}')
while IFS=$'\t' read -r unit state; do
    _SVC_ENABLED["$unit"]="$state"
done < <(systemctl list-unit-files --type=service --no-legend --no-pager \
    --plain 2>/dev/null | awk '{printf "%s\t%s\n", $1, $2}')
# ──────────────────────────────────────────────────────────

check_service() {
    local svc="${1}.service"
    local display_name="$2"
    local config_check="$3"

    local status="⭕ Disabled"
    local color="\e[0;91m"

    local en="${_SVC_ENABLED[$svc]:-disabled}"
    local ac="${_SVC_ACTIVE[$svc]:-inactive}"

    if [[ "$en" == "enabled" || "$en" == "static" ]]; then
        if [[ "$ac" == "active" ]]; then
            status="🟢 Running"; color="\e[0;92m"
        else
            status="🟡 Stopped"; color="\e[0;93m"
        fi
    fi

    local config_status=" (not configured)"
    if [[ -n "$config_check" ]] && eval "$config_check" &>/dev/null; then
        config_status=" (configured)"
    fi

    printf " \e[1;36m%-18s\e[0m: %b%s\e[0m%s\n" "$display_name" "$color" "$status" "$config_status"
}

echo ""
printf "\e[0;90m Hive Services: \x1B[0m\n"
echo ""

check_service "tailscaled"                "Tailscale VPN"        '[[ -n "${TAILSCALE_OAUTH_SECRET}" ]]'
check_service "provision-node"            "Node Provision"       "true"
check_service "prometheus-node-exporter"  "Metrics Export"       "true"
check_service "ufw"                       "Firewall"             '[[ "${_SVC_ACTIVE[ufw.service]}" == "active" ]]'
check_service "fail2ban"                  "Intrusion Prevention" '[[ "${_SVC_ACTIVE[fail2ban.service]}" == "active" ]]'

[[ -n "${_SVC_ENABLED[xray.service]:-}" ]] && \
    check_service "xray"        "Xray Proxy"       '[[ -f "/etc/xray/config.json" ]]'
[[ -n "${_SVC_ENABLED[cloudflared.service]:-}" ]] && \
    check_service "cloudflared" "Cloudflare Tunnel" '[[ -n "${CF_API_TOKEN}" ]]'
[[ -n "${_SVC_ENABLED[frpc.service]:-}" ]] && \
    check_service "frpc"        "FRP Client"        '[[ -n "${FRP_SERVER_ADDR}" ]]'
[[ -n "${_SVC_ENABLED[easytier.service]:-}" ]] && \
    check_service "easytier"    "EasyTier P2P"      '[[ -n "${EASYTIER_NETWORK_NAME}" ]]'

# ── 等后台网络检测完成 ────────────────────────────────────
echo ""
printf "\e[0;90m Network Status: \x1B[0m\n"
echo ""

wait "${_INET_PID}" 2>/dev/null || true
if [[ "$(cat "${_TMP}/inet" 2>/dev/null)" == "connected" ]]; then
    printf " \e[1;36m%-18s\e[0m: \e[0;92m🟢 Connected\e[0m\n"    "Internet Access"
else
    printf " \e[1;36m%-18s\e[0m: \e[0;91m⭕ Disconnected\e[0m\n" "Internet Access"
fi

if [[ -n "${_TS_PID:-}" ]]; then
    wait "${_TS_PID}" 2>/dev/null || true
    if [[ "$(cat "${_TMP}/ts" 2>/dev/null)" == "connected" ]]; then
        printf " \e[1;36m%-18s\e[0m: \e[0;92m🟢 Connected\e[0m\n"    "Tailscale Network"
    else
        printf " \e[1;36m%-18s\e[0m: \e[0;91m⭕ Disconnected\e[0m\n" "Tailscale Network"
    fi
fi

rm -rf "${_TMP}"
# ──────────────────────────────────────────────────────────

# Node Identity
INTERFACE=$(ip link show | grep -E '^[0-9]+: (eth|en|wl)' | head -1 | cut -d: -f2 | tr -d ' ')
MAC_ADDR=$(ip link show "$INTERFACE" 2>/dev/null | grep -o -E '([a-f0-9]{2}:){5}[a-f0-9]{2}' | head -1)
if [[ -n "$MAC_ADDR" ]]; then
    MAC6=$(echo "$MAC_ADDR" | tr -d : | tail -c 7)
    echo ""
    printf "\e[0;90m Node Identity: \x1B[0m\n"
    echo ""
    printf " \e[1;36m%-18s\e[0m: \e[0;94m%s\e[0m\n" "MAC Address" "$MAC_ADDR"
    printf " \e[1;36m%-18s\e[0m: \e[0;94mhive-%s\e[0m\n" "Node ID" "$MAC6"
    [[ -n "${CF_DOMAIN}" ]] && \
        printf " \e[1;36m%-18s\e[0m: \e[0;94mhive-%s.%s\e[0m\n" "Public Domain" "$MAC6" "${CF_DOMAIN}"
fi

# Connection Info
if [[ -f /etc/hive/node-info ]]; then
    safe_source /etc/hive/node-info

    echo ""
    printf "\e[0;90m Connection Info: \x1B[0m\n"
    echo ""

    [[ -n "${TAILSCALE_HOST:-}" ]] && \
        printf " \e[1;36m%-18s\e[0m: \e[0;93mssh root@%s\e[0m\n" "Tailscale" "${TAILSCALE_HOST}"

    [[ -n "${EASYTIER_IP:-}" ]] && \
        printf " \e[1;36m%-18s\e[0m: \e[0;93mssh root@%s\e[0m\n" "EasyTier" "${EASYTIER_IP}"

    if [[ -n "${FRP_PORT:-}" && -n "${FRP_SERVER_ADDR:-}" ]]; then
        printf " \e[1;36m%-18s\e[0m: \e[0;93mssh -p %s root@%s\e[0m\n" "FRP" "${FRP_PORT}" "${FRP_SERVER_ADDR}"
    fi

    [[ -n "${CF_URL:-}" ]] && \
        printf " \e[1;36m%-18s\e[0m: \e[0;93m%s\e[0m\n" "CF Proxy" "${CF_URL}"

    if [[ -n "${XRAY_UUID:-}" && -n "${CF_URL:-}" ]]; then
        CF_HOST="${CF_URL#https://}"
        VLESS_LINK="vless://${XRAY_UUID}@${CF_HOST}:443?type=ws&security=tls&path=%2Fray#${HOSTNAME:-hive}"
        printf " \e[1;36m%-18s\e[0m: \e[0;93m%s\e[0m\n" "Xray (VLESS)" "${VLESS_LINK}"
    fi
fi

echo ""

exit 0
